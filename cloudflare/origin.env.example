# Copy values into your shell or an untracked local env file. Never commit real secrets.
export NATIVAS_DOMAIN="nativas.ai"
export NATIVAS_API_ORIGIN="https://api.nativas.ai"
export NATIVAS_EDGE_TOKEN="replace-with-a-long-random-token"
export NATIVAS_CAPTURE_ORIGIN_SECRET="replace-with-a-different-long-random-secret"
# ARTIFACT_DELIVERY_SECRET is a Worker-only secret and must not be present on the laptop.
# Needed only by scripts/cloudflare/run-tunnel.sh after a named tunnel is created in Cloudflare.
export CLOUDFLARE_TUNNEL_TOKEN="paste-the-Cloudflare-tunnel-token"

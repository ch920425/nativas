{
  "name": "nativas-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:local": "node apps/local-server/src/dev.ts",
    "dev:api": "node apps/local-server/src/server.ts",
    "build:cloudflare": "VITE_TRANSPORT=live VITE_API_BASE_URL='' npm run build --workspace @nativas/web",
    "deploy:cloudflare": "npm run build:cloudflare && npx wrangler deploy",
    "preflight:cloudflare": "node scripts/cloudflare/preflight.mjs",
    "test:backend": "node --test tests/backend/*.test.ts",
    "test:local": "node --test tests/local/*.test.ts",
    "test:cloudflare": "node --test tests/cloudflare/*.test.mjs",
    "test:convex": "node --test tests/convex/*.test.ts",
    "test": "npm run test:backend && npm run test:local && npm run test:cloudflare && node --test tests/kb/*.test.mjs && npm run test:convex && npm test --workspace @nativas/web",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate": "bash scripts/validate-repo.sh && bash scripts/validate-hermes-spec.sh"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "convex": "^1.42.1",
    "dodopayments": "^2.42.2"
  }
}

{
  "name": "nativas-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:local": "node apps/local-server/src/dev.ts",
    "dev:api": "node apps/local-server/src/server.ts",
    "test:backend": "node --test tests/backend/*.test.ts",
    "test:local": "node --test tests/local/*.test.ts",
    "test": "npm run test:backend && npm run test:local && node --test tests/kb/*.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate": "bash scripts/validate-repo.sh && bash scripts/validate-hermes-spec.sh"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "typescript": "^5.9.3"
  }
}

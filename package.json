{
  "name": "navitas-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test:backend": "node --test tests/backend/*.test.ts",
    "test": "npm run test:backend && node --test tests/kb/*.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate": "bash scripts/validate-repo.sh && bash scripts/validate-hermes-spec.sh"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "typescript": "^5.9.3"
  }
}
